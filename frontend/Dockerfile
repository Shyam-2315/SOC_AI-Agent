FROM node:22-alpine AS build

WORKDIR /app

COPY package.json ./
COPY bun.lock ./

RUN npm install --no-audit --no-fund

COPY . .

ARG VITE_API_BASE_URL=http://127.0.0.1
ARG VITE_WS_BASE_URL=ws://127.0.0.1
ARG VITE_DEMO_MODE=false
ARG VITE_DEMO_ADMIN_EMAIL=demo.admin@aisoc.dev
ARG VITE_DEMO_ADMIN_PASSWORD=DemoAdmin123!
ARG VITE_DEMO_COLLECTOR_TOKEN=demo-collector-token

ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
ENV VITE_WS_BASE_URL=$VITE_WS_BASE_URL
ENV VITE_DEMO_MODE=$VITE_DEMO_MODE
ENV VITE_DEMO_ADMIN_EMAIL=$VITE_DEMO_ADMIN_EMAIL
ENV VITE_DEMO_ADMIN_PASSWORD=$VITE_DEMO_ADMIN_PASSWORD
ENV VITE_DEMO_COLLECTOR_TOKEN=$VITE_DEMO_COLLECTOR_TOKEN

RUN npm run build

FROM node:22-alpine AS runtime

WORKDIR /app
ENV NODE_ENV=production
ENV HOST=0.0.0.0
ENV PORT=8080

COPY --from=build /app /app

EXPOSE 8080

CMD ["node", "serve-worker.mjs"]
