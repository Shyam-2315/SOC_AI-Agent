APP_NAME=AI SOC Platform
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
DOCS_ENABLED=true
LOG_LEVEL=INFO
LOG_JSON=false
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=1

TRUSTED_HOSTS=localhost,127.0.0.1,backend,testserver
HTTPS_REDIRECT=false
CORS_ALLOW_CREDENTIALS=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MONGO_URL=mongodb://mongo:27017
DATABASE_NAME=ai_soc

REDIS_URL=redis://redis:6379/0
ALERT_PROCESSING_MODE=sync
REALTIME_EVENTS_CHANNEL=realtime-events

JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PUBLIC_REGISTRATION_ENABLED=true

COLLECTOR_API_KEYS=test-collector-token:6a016ae4ffb4489b3a44ba89
COLLECTOR_BATCH_MAX_SIZE=100
SYSLOG_ENABLED=false
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=5514
SYSLOG_COLLECTOR_TOKEN=

AUTH_RATE_LIMIT_PER_MINUTE=20
INGESTION_RATE_LIMIT_PER_MINUTE=120

VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
VITE_DEMO_MODE=false
VITE_DEMO_ADMIN_EMAIL=demo.admin@aisoc.dev
VITE_DEMO_ADMIN_PASSWORD=DemoAdmin123!
VITE_DEMO_COLLECTOR_TOKEN=test-collector-token
