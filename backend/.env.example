APP_NAME=AI SOC Platform
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false
DOCS_ENABLED=false
LOG_LEVEL=INFO
LOG_JSON=true
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=4

TRUSTED_HOSTS=soc-api.example.com
HTTPS_REDIRECT=true
CORS_ALLOW_CREDENTIALS=true
CORS_ORIGINS=https://soc.example.com,http://127.0.0.1,http://localhost,http://127.0.0.1:8080,http://localhost:8080

MONGO_INITDB_ROOT_USERNAME=mongo_root
MONGO_INITDB_ROOT_PASSWORD=replace-with-root-password
MONGO_APP_USERNAME=ai_soc_app
MONGO_APP_PASSWORD=replace-with-app-password
MONGO_APP_DATABASE=ai_soc
MONGO_URL=mongodb://ai_soc_app:replace-with-app-password@mongo:27017/ai_soc?authSource=ai_soc
DATABASE_NAME=ai_soc
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=10000
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=0

REDIS_PASSWORD=replace-with-redis-password
REDIS_URL=redis://:replace-with-redis-password@redis:6379/0

ALERT_PROCESSING_MODE=celery
CELERY_BROKER_URL=redis://:replace-with-redis-password@redis:6379/0
CELERY_RESULT_BACKEND=redis://:replace-with-redis-password@redis:6379/0
CELERY_TASK_DEFAULT_QUEUE=alert-processing
CELERY_WORKER_CONCURRENCY=4
ALERT_EVENTS_CHANNEL=alert-events
REALTIME_EVENTS_CHANNEL=realtime-events
WEBSOCKET_SEND_QUEUE_SIZE=1000
AUTH_RATE_LIMIT_PER_MINUTE=20
INGESTION_RATE_LIMIT_PER_MINUTE=120

JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ALGORITHM=HS256
JWT_ISSUER=soc-api.example.com
JWT_AUDIENCE=soc-platform
ACCESS_TOKEN_EXPIRE_MINUTES=60
PUBLIC_REGISTRATION_ENABLED=false

DEMO_MODE=false
DEMO_ORG_NAME=Demo SOC
DEMO_ADMIN_EMAIL=demo.admin@aisoc.dev
DEMO_ADMIN_PASSWORD=replace-with-demo-password
DEMO_COLLECTOR_TOKEN=replace-with-demo-collector-token

COLLECTOR_API_KEYS=replace-with-secure-collector-token:replace-with-organization-id
COLLECTOR_BATCH_MAX_SIZE=100
SYSLOG_ENABLED=false
SYSLOG_HOST=0.0.0.0
SYSLOG_PORT=5514
SYSLOG_COLLECTOR_TOKEN=

NGINX_SERVER_NAME=soc-api.example.com
NGINX_CLIENT_MAX_BODY_SIZE=10m
NGINX_SSL_ENABLED=false
NGINX_SSL_CERT_PATH=/etc/nginx/certs/server.crt
NGINX_SSL_KEY_PATH=/etc/nginx/certs/server.key

VITE_DEMO_MODE=false
VITE_API_BASE_URL=http://127.0.0.1
VITE_WS_BASE_URL=ws://127.0.0.1
VITE_DEMO_ADMIN_EMAIL=demo.admin@aisoc.dev
VITE_DEMO_ADMIN_PASSWORD=replace-with-demo-password
VITE_DEMO_COLLECTOR_TOKEN=replace-with-demo-collector-token
